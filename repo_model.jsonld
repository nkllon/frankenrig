  {
    "@id": "urn:lou:obs-pip#SourceUrlDiscovery",
    "@type": [
      "http://www.w3.org/2000/01/rdf-schema#Resource"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Underlying window sources (URLs and views)"
      }
    ],
    "urn:lou:obs-pip#note": [
      {
        "@value": "Four OBS sources map to four Chrome windows in separate views (Control-Left/Right). All four are Chrome. Window 1 (main): YouTube bootybunt. Window 2 (lower-left): Deutsche Welle Live (YouTube). Window 3 (lower-right): French news (e.g. France 24) live. Window 4 (bottom center): BBC News Live via BBC website (e.g. bbc.co.uk/iplayer/live/bbcnews). Stable URLs in evidence/obs_pip_source_urls.json; capture exact URLs via capture_chrome_window_urls.sh. Reconstruct: open four URLs in four full-screen Chrome windows, get window IDs (click or identify), run obs_rebuild_pip_arrangement.py --window1 ID1 --window2 ID2 --window3 ID3 and --add-fourth-center --window4 ID4."
      }
    ]
  },
