  {
    "@id": "urn:lou:obs-pip#Act_IdentifyWindowByClick",
    "@type": [
      "urn:lou:obs-pip#Action"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Identify target window by click for OBS capture binding"
      }
    ],
    "urn:lou:obs-pip#hasEvidence": [
      {
        "@id": "urn:lou:obs-pip#Ev_IdentifyWindowScript"
      }
    ],
    "urn:lou:obs-pip#note": [
      {
        "@value": "Standalone Python script: run script, click desired window within 7s; outputs window ID (id= N title= app= pid=). Use that ID to configure or re-bind OBS window capture. Solves correct-window identification so OBS can be pointed at the clicked window."
      }
    ]
  },
  {
    "@id": "urn:lou:obs-pip#Act_RebuildPipArrangement",
    "@type": [
      "urn:lou:obs-pip#Action"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@value": "Reconstruct PiP arrangement from window IDs"
      }
    ],
    "urn:lou:obs-pip#hasEvidence": [
      {
        "@id": "urn:lou:obs-pip#Ev_RebuildScript"
      }
    ],
    "urn:lou:obs-pip#note": [
      {
        "@value": "Script: obs_rebuild_pip_arrangement.py. Two windows: window1→PiP Capture, window2→Aux2; layout main + lower-left; open preview. Third: --lower-right (optional --window3 ID) creates Aux3LR_<timestamp>, lower-right insets 540/125, alignment 8. --fix-aux3 re-applies transform to source name starting with Aux3LR. --diagnose prints scene items and canvas. SetSceneItemTransform bounds >= 1."
      }
    ]
  },
